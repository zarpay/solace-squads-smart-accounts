# frozen_string_literal: true

source 'https://rubygems.org'

# Consume the gem exactly as a host app would — by name. Bundler resolves its
# runtime dependencies (solace, base64) from the gemspec; the path just points at
# this repo's copy instead of RubyGems.
gem 'solace-squads-smart-accounts', path: '../gem'

# A test framework for the sanity checks themselves (not a dependency of the gem).
gem 'minitest', '~> 5.0'
